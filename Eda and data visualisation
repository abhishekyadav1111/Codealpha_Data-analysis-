    "Month": ["Jan", "Feb", "Mar", "Apr", "May", "Jun"],
    "Sales": [1200, 1500, 1700, 1600, 2100, 2500]
})

sales_df.to_csv(viz_base / "sales_data.csv", index=False)

# Chart
